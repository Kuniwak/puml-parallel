@startuml

' The implementation refines this process in the stable failures model.
' A line-oriented reader may implement one submitted line as EventInputRunes
' followed by EventPressEnter; implementation state need not correspond to
' the states below.
'
' type json = Boolean | Number | String | Dict ((string * json) list) | Array (json list)
' type event = Event string | Tau
' type trace = event list
' fun appendVisible :: trace => event => trace
'     where appendVisible trace Tau = trace
'       and appendVisible trace event = trace @ [event]
'
' type stateGroupID = StateGroupID string
' type stateGroup = StateGroup stateGroupID (string list)
' fun stateGroupIDOf :: stateGroup => stateGroupID
'     where stateGroupIDOf (StateGroup stateGroupID _) = stateGroupID
' fun stateVarNamesOf :: stateGroup => string list
'     where stateVarNamesOf (StateGroup _ stateVarNames) = stateVarNames
'
' type state = State stateGroupID ((string * json) list)
' fun stateGroupIDOfState :: state => stateGroupID
'     where stateGroupIDOfState (State stateGroupID _) = stateGroupID
'
' type guard = Guard string
' type post = Post string
' type postSolverResult =
'       PostSolverResultOK state
'     | PostSolverResultNoSolutions
'     | PostSolverResultInvalidStateVarValuesLength
'     | PostSolverResultSyntaxError string
'
' solvePost is intentionally abstract. The initial implementation reads a JSON
' array and therefore cannot return PostSolverResultNoSolutions. A future
' machine evaluator for guards and posts may return it when a guard-satisfying
' pre-state has no post-state satisfying the postcondition. It is retained as
' an escape hatch for an inconsistent guard or postcondition.
' fun solvePost :: stateGroup => guard => post => string => postSolverResult
'
' type historyEntry = HistoryEntry state trace
' type history = historyEntry list
' type trans = Trans stateGroup guard post event stateGroup
' type csdf = CSDF (stateGroup list) (trans list) stateGroup post
' type common = Common csdf history
' fun csdfOf :: common => csdf
'     where csdfOf (Common csdf _) = csdf
' fun historyOf :: common => history
'     where historyOf (Common _ history) = history
' fun traceOf :: common => trace
'     where traceOf (Common _ []) = []
'       and traceOf (Common _ history) = traceOfHistoryEntry (last history)
' type fatal = FileNotExists string | SyntaxError string | NoSolutionsFound

state "starting" as starting

state "willAskStateVars" as willAskStateVars
willAskStateVars: common ; common
willAskStateVars: event ; event
willAskStateVars: stateGroup ; stateGroup
willAskStateVars: guard ; guard
willAskStateVars: post ; post

state "waitingStateVars" as waitingStateVars
waitingStateVars: common ; common
waitingStateVars: event ; event
waitingStateVars: stateGroup ; stateGroup
waitingStateVars: guard ; guard
waitingStateVars: post ; post
waitingStateVars: input ; string
waitingStateVars: curPos ; nat

state "willAskCommand" as willAskCommand
willAskCommand: common ; common
willAskCommand: state ; state

state "waitingCommand" as waitingCommand
waitingCommand: common ; common
waitingCommand: state ; state
waitingCommand: input ; string
waitingCommand: curPos ; nat

state "willDisplayTrans" as willDisplayTrans
willDisplayTrans: common ; common
willDisplayTrans: state ; state

state "willDisplayTrace" as willDisplayTrace
willDisplayTrace: common ; common
willDisplayTrace: state ; state

state "willDisplayHistory" as willDisplayHistory
willDisplayHistory: common ; common
willDisplayHistory: state ; state

state "willDisplayHelp" as willDisplayHelp
willDisplayHelp: common ; common
willDisplayHelp: state ; state

state "willDisplayEmptyLine" as willDisplayEmptyLine
willDisplayEmptyLine: common ; common
willDisplayEmptyLine: state ; state

state "willDisplayError1" as willDisplayError1
willDisplayError1: common ; common
willDisplayError1: event ; event
willDisplayError1: stateGroup ; stateGroup
willDisplayError1: guard ; guard
willDisplayError1: post ; post
willDisplayError1: input ; string
willDisplayError1: curPos ; nat
willDisplayError1: error ; string

state "willDisplayError2" as willDisplayError2
willDisplayError2: common ; common
willDisplayError2: state ; state
willDisplayError2: error ; string

state "willDisplayFatal" as willDisplayFatal
willDisplayFatal: fatal ; fatal

state "willExit" as willExit

[*] --> starting

starting --> willAskStateVars : EventLaunch csdfPath ; fileExists csdfPath and parseCSDF csdfPath = ValidCSDF csdf ; common' = Common csdf [] and stateGroup' = initialStateGroup csdf and guard' = True and post' = initialPost csdf and event' = Tau
starting --> willDisplayFatal : EventLaunch csdfPath ; not fileExists csdfPath ; fatal' = FileNotExists csdfPath
starting --> willDisplayFatal : EventLaunch csdfPath ; fileExists csdfPath and parseCSDF csdfPath = InvalidCSDF error ; fatal' = SyntaxError error

willDisplayFatal --> willExit : EventDisplayFatal fatal ; true ; true

willAskStateVars --> waitingStateVars : EventDisplayStateGroup stateGroup post ; true ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = "" and curPos' = 0

waitingStateVars --> waitingStateVars : EventInputRunes runes ; length runes > 0 ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = insertRunes runes curPos input and curPos' = curPos + length runes
waitingStateVars --> waitingStateVars : EventCtrlD ; input != "" ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = deleteRuneAtJustAfterCursor input curPos and curPos' = curPos
waitingStateVars --> waitingStateVars : EventCtrlH ; curPos > 0 ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = deleteRuneAtJustBeforeCursor input curPos and curPos' = curPos - 1
waitingStateVars --> willAskCommand : EventPressEnter ; solvePost stateGroup guard post input = PostSolverResultOK state ; common' = Common (csdfOf common) ((historyOf common) @ [HistoryEntry state (appendVisible (traceOf common) event)]) and state' = state
waitingStateVars --> willDisplayError1 : EventPressEnter ; solvePost stateGroup guard post input = PostSolverResultInvalidStateVarValuesLength ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = input and curPos' = curPos and error' = "State variable values length mismatch"
waitingStateVars --> willDisplayError1 : EventPressEnter ; solvePost stateGroup guard post input = PostSolverResultNoSolutions ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = input and curPos' = curPos and error' = "No solutions"
waitingStateVars --> willDisplayError1 : EventPressEnter ; solvePost stateGroup guard post input = PostSolverResultSyntaxError error ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = input and curPos' = curPos and error' = error
waitingStateVars --> willAskCommand : EventCtrlC ; length (historyOf common) > 0 ; common' = common and state' = stateOfHistoryEntry (last (historyOf common))
waitingStateVars --> willDisplayFatal : EventCtrlC ; length (historyOf common) = 0 ; fatal' = NoSolutionsFound
waitingStateVars --> willExit : EventCtrlD ; input = "" ; true

willDisplayError1 --> waitingStateVars : EventDisplayError error ; true ; common' = common and stateGroup' = stateGroup and guard' = guard and post' = post and event' = event and input' = input and curPos' = curPos

willAskCommand --> waitingCommand : EventDisplayTrans state transitions ; length (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) > 0 and transitions = transByStateGroupID (csdfOf common) (stateGroupIDOfState state) ; common' = common and state' = state and input' = "" and curPos' = 0
willAskCommand --> waitingCommand : EventDisplayDeadlock state ; length (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) = 0 ; common' = common and state' = state and input' = "" and curPos' = 0

waitingCommand --> waitingCommand : EventInputRunes runes ; length runes > 0 ; common' = common and state' = state and input' = insertRunes runes curPos input and curPos' = curPos + length runes
waitingCommand --> waitingCommand : EventCtrlD ; input != "" ; common' = common and state' = state and input' = deleteRuneAtJustAfterCursor input curPos and curPos' = curPos
waitingCommand --> waitingCommand : EventCtrlH ; curPos > 0 ; common' = common and state' = state and input' = deleteRuneAtJustBeforeCursor input curPos and curPos' = curPos - 1
waitingCommand --> willDisplayTrans : EventPressEnter ; input = "l" ; common' = common and state' = state
waitingCommand --> willDisplayTrace : EventPressEnter ; input = "t" ; common' = common and state' = state
waitingCommand --> willDisplayHistory : EventPressEnter ; input = "h" ; common' = common and state' = state
waitingCommand --> willDisplayHelp : EventPressEnter ; input = "?" or input = "help" ; common' = common and state' = state
waitingCommand --> willAskStateVars : EventPressEnter ; input = "s " + index and parseNat index = ValidNat n and n < length (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) ; common' = common and trans = (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) ! n and stateGroup' = destinationOf trans and guard' = guardOf trans and post' = postOf trans and event' = eventOf trans
waitingCommand --> willDisplayError2 : EventPressEnter ; input = "s" ; common' = common and state' = state and error' = "required an index of transition"
waitingCommand --> willDisplayError2 : EventPressEnter ; input = "s " + index and parseNat index = InvalidNat ; common' = common and state' = state and error' = "Not a natural number"
waitingCommand --> willDisplayError2 : EventPressEnter ; input = "s " + index and parseNat index = ValidNat n and n >= length (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) ; common' = common and state' = state and error' = "Index out of range"
waitingCommand --> willDisplayTrans : EventPressEnter ; input = "j " + index and parseNat index = ValidNat n and n < length (historyOf common) ; entry = (historyOf common) ! n and common' = Common (csdfOf common) ((historyOf common) @ [entry]) and state' = stateOfHistoryEntry entry
waitingCommand --> willDisplayError2 : EventPressEnter ; input = "j" ; common' = common and state' = state and error' = "required an index of history"
waitingCommand --> willDisplayError2 : EventPressEnter ; input = "j " + index and parseNat index = InvalidNat ; common' = common and state' = state and error' = "Not a natural number"
waitingCommand --> willDisplayError2 : EventPressEnter ; input = "j " + index and parseNat index = ValidNat n and n >= length (historyOf common) ; common' = common and state' = state and error' = "Index out of range"
waitingCommand --> willDisplayError2 : EventPressEnter ; hasPrefix "l " input or hasPrefix "t " input or hasPrefix "h " input or hasPrefix "? " input or hasPrefix "help " input ; common' = common and state' = state and error' = "invalid arguments"
waitingCommand --> willDisplayError2 : EventPressEnter ; input is not a valid command and input != "" ; common' = common and state' = state and error' = "invalid command"
waitingCommand --> willDisplayEmptyLine : EventPressEnter ; input = "" ; common' = common and state' = state
waitingCommand --> willExit : EventCtrlD ; input = "" ; true
waitingCommand --> willExit : EventCtrlC ; true ; true

willDisplayTrans --> waitingCommand : EventDisplayTrans state transitions ; length (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) > 0 and transitions = transByStateGroupID (csdfOf common) (stateGroupIDOfState state) ; common' = common and state' = state and input' = "" and curPos' = 0
willDisplayTrans --> waitingCommand : EventDisplayDeadlock state ; length (transByStateGroupID (csdfOf common) (stateGroupIDOfState state)) = 0 ; common' = common and state' = state and input' = "" and curPos' = 0
willDisplayTrace --> waitingCommand : EventDisplayTrace (traceOf common) ; true ; common' = common and state' = state and input' = "" and curPos' = 0
willDisplayHistory --> waitingCommand : EventDisplayHistory (historyOf common) ; true ; common' = common and state' = state and input' = "" and curPos' = 0
willDisplayHelp --> waitingCommand : EventDisplayHelp ; true ; common' = common and state' = state and input' = "" and curPos' = 0
willDisplayEmptyLine --> waitingCommand : EventDisplayEmptyLine ; true ; common' = common and state' = state and input' = "" and curPos' = 0
willDisplayError2 --> waitingCommand : EventDisplayError error ; true ; common' = common and state' = state and input' = "" and curPos' = 0

willExit --> [*]

@enduml
